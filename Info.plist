<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- App Store export compliance: BumpyRide only uses standard iOS TLS/HTTPS
	     for its sync transport — no custom or non-exempt cryptography.  Setting
	     this to false qualifies for the standard exemption so App Store Connect
	     stops asking on every upload. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- iCloud Documents container metadata.  Without this dict, iCloud Drive
	     shows the container under its raw bundle identifier
	     (iCloud.com.herbertindustries.BumpyRide) which is ugly and confusing
	     for users.  With it, the container appears as "BumpyRide" in Files
	     app under iCloud Drive. NSUbiquitousContainerIsDocumentScopePublic =
	     YES is required for the container to be visible in Files at all (vs.
	     hidden, app-private storage). -->
	<key>NSUbiquitousContainers</key>
	<dict>
		<key>iCloud.com.herbertindustries.BumpyRide</key>
		<dict>
			<key>NSUbiquitousContainerIsDocumentScopePublic</key>
			<true/>
			<key>NSUbiquitousContainerSupportedFolderLevels</key>
			<string>Any</string>
			<key>NSUbiquitousContainerName</key>
			<string>BumpyRide</string>
		</dict>
	</dict>

	<key>NSLocationWhenInUseUsageDescription</key>
	<string>BumpyRide uses your location to map the route of your ride.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>BumpyRide records your route while you ride so bumpiness can be mapped to location.</string>
	<key>NSMotionUsageDescription</key>
	<string>BumpyRide uses motion sensors to measure bumpiness along your route.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>BumpyRide saves exported ride images to your photo library.</string>

	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>

	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
		<key>UISceneConfigurations</key>
		<dict/>
	</dict>

	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!--
	  Launch screen: green background (#34C759, iOS system green) with the
	  app icon centered at ~200pt.  The icon is sourced from a separate
	  LaunchIcon Image Set (1x/2x/3x) rather than the AppIcon asset, so we
	  can control its on-screen size — UILaunchScreen renders the image at
	  its natural point size, and the AppIcon's 1024px source would render
	  enormous.
	  UIImageRespectsSafeAreaInsets is left false so the icon stays
	  centered on the whole screen rather than getting nudged below the
	  notch/Dynamic Island.
	-->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
		<key>UIImageName</key>
		<string>LaunchIcon</string>
		<key>UIImageRespectsSafeAreaInsets</key>
		<false/>
	</dict>

	<key>UISupportedInterfaceOrientations~iphone</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
